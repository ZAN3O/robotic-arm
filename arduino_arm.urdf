<?xml version="1.0"?>
<robot name="howtomechatronics_arm">

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.06"/>
      </geometry>
      <material name="black"/>
      <origin rpy="0 0 0" xyz="0 0 0.02"/>
    </visual>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.05"/> 
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0.025"/> </visual>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.13"/>
      </geometry>
      <material name="white"/>
      <origin rpy="0 0 0" xyz="0 0 0.065"/> </visual>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.13"/>
      </geometry>
      <material name="blue"/>
      <origin rpy="0 0 0" xyz="0 0 0.065"/> </visual>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.11"/>
      </geometry>
      <material name="black"/>
      <origin rpy="0 0 0" xyz="0 0 0.055"/> </visual>
    </link>
  
  <joint name="joint_tip" type="fixed">
    <parent link="link_4"/>
    <child link="tip"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
  </joint>
  
  <link name="tip">
     </link>

</robot>